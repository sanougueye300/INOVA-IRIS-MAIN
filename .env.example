# Supabase (client)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Supabase (server / edge functions)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# SMS OTP (Twilio) — sans config, le code OTP s'affiche en mode dev dans les toasts
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# E-mails professionnels INOVA-IRIS (Resend) — sans config, fallback Supabase Auth
RESEND_API_KEY=
AUTH_EMAIL_FROM=INOVA-IRIS <noreply@inova-iris.sn>

# IA
GEMINI_API_KEY=

# Tests auth (optionnel)
TEST_USER_EMAIL=
TEST_USER_PASSWORD=

# =============================================================
# STACK SOC — Connecteurs externes (serveur Linux dédié/VPS)
# Ces variables sont utilisées par les Supabase Edge Functions.
# Le serveur Wazuh/TheHive/MISP/Shuffle doit être accessible
# depuis internet (VPS, serveur dédié ou cloud provider).
# Ne jamais exposer ces clés côté client (pas de VITE_ prefix).
# =============================================================

# Wazuh SIEM/EDR
# URL de l'API REST Wazuh (port 55000 par défaut)
# Ex: https://YOUR_VPS_IP:55000
WAZUH_URL=
WAZUH_USER=wazuh-wui
WAZUH_PASSWORD=

# TheHive 5 — Incident Response Platform
# URL de l'instance TheHive (port 9000 par défaut)
# Ex: https://YOUR_VPS_IP:9000
THEHIVE_URL=
# Clé API TheHive : Administration → API Keys
THEHIVE_API_KEY=

# MISP — Threat Intelligence Sharing
# URL de l'instance MISP
# Ex: https://YOUR_VPS_IP ou https://misp.yourdomain.com
MISP_URL=
# Clé API MISP : Event Actions → Automation → Auth key
MISP_API_KEY=

# VirusTotal — Malware & Threat Analysis
# Clé API gratuite sur https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# Shuffle SOAR — Security Orchestration
# URL de l'instance Shuffle (port 3001 par défaut)
# Ex: http://YOUR_VPS_IP:3001
SHUFFLE_URL=
# Clé API Shuffle : Profile → Generate API Key
SHUFFLE_API_KEY=

# DFIR-IRIS — Digital Forensics & Incident Response
# URL de l'instance IRIS (port 443 par défaut)
# Ex: https://YOUR_VPS_IP
IRIS_URL=
# Clé API IRIS : My Profile → API Key
IRIS_API_KEY=
