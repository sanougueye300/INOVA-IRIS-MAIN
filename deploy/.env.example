# =============================================================================
# Variables de la stack SOC — COPIER vers .env et REMPLACER toutes les valeurs
#   cp .env.example .env
# Générer un secret fort :  openssl rand -hex 32
# Ne JAMAIS committer le .env réel (déjà dans .gitignore).
# =============================================================================

# IP ou nom de domaine public du VPS (sans http://)
VPS_HOST=203.0.113.10

# --- TheHive ---
THEHIVE_SECRET=CHANGEME_openssl_rand_hex_32
# Clé API Cortex pour l'enrichissement (à remplir APRÈS avoir démarré Cortex et généré la clé dans son UI)
CORTEX_API_KEY=

# --- MinIO (stockage objets TheHive) ---
MINIO_USER=minioadmin
MINIO_PASSWORD=CHANGEME_strong_password

# --- MISP ---
MISP_ADMIN_EMAIL=admin@inova-iris.com
MISP_ADMIN_PASSWORD=CHANGEME_strong_password
MISP_DB_PASSWORD=CHANGEME_strong_password
MISP_DB_ROOT_PASSWORD=CHANGEME_strong_password
